# Auth service — copy to .env and fill in values

BETTER_AUTH_URL=http://localhost:3001
TRUSTED_ORIGINS=http://localhost:5173,https://tradelikeme.xyz
BETTER_AUTH_SECRET=
SUPABASE_DB_URL=
ADMIN_EMAILS=

# Google OAuth — console.cloud.google.com → APIs & Services → Credentials
# Redirect URI: https://auth.tradelikeme.xyz/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — github.com/settings/developers → OAuth Apps
# Callback URL: https://auth.tradelikeme.xyz/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# X/Twitter OAuth — developer.x.com → Projects & Apps
# Callback URL: https://auth.tradelikeme.xyz/api/auth/callback/twitter
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
