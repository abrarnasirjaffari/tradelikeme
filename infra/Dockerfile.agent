# Stage 1: Install dependencies
FROM python:3.11-slim AS builder

WORKDIR /app

# System deps needed by playwright + zetamarkets-py (Rust wheel) + psycopg2
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install Playwright Chromium browser
RUN playwright install chromium --with-deps

# Stage 2: Runtime
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    curl \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Copy Playwright browsers and deps from builder
COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin
COPY --from=builder /root/.cache/ms-playwright /home/appuser/.cache/ms-playwright

# Copy Playwright system deps (shared libraries)
COPY --from=builder /usr/lib/x86_64-linux-gnu /usr/lib/x86_64-linux-gnu

COPY trading_agent/ ./trading_agent/
COPY requirements.txt .

# Persistent data directory (SQLite DBs, chart screenshots)
RUN mkdir -p /app/data

RUN useradd -m appuser && chown -R appuser:appuser /app/data
USER appuser

CMD ["python", "-m", "trading_agent.strategies.sd_zones.agent"]
