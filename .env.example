# TradeLikeMe — Environment Variables
# Copy this to .env and fill in your values

# Helius RPC
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# Phantom Wallet (agent sub-account)
PHANTOM_PRIVATE_KEY=

# Solana
SOLANA_NETWORK=devnet
DEVNET_AGENT_KEYPAIR_PATH=~/.config/solana/devnet-agent.json

# AWS Bedrock (Claude Opus 4.6)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# WEEX
WEEX_API_KEY=
WEEX_SECRET=
WEEX_PASSPHRASE=

# Bybit
BYBIT_API_KEY=
BYBIT_SECRET=

# BingX
BINGX_API_KEY=
BINGX_SECRET=

# Binance
BINANCE_API_KEY=
BINANCE_SECRET=

# Bitget
BITGET_API_KEY=
BITGET_SECRET=
BITGET_PASSPHRASE=

# GitHub
GITHUB_PAT=

# Platform
PLATFORM_WALLET_PUBKEY=

# Anchor Vault Program (devnet)
PROGRAM_ID=
PROGRAM_DATA_ADDRESS=
PROGRAM_UPGRADE_AUTHORITY=
PROGRAM_DEPLOY_SLOT=
DEVNET_AGENT_PUBKEY=

# USDC mint on devnet (Circle's official devnet USDC)
USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Frontend (Supabase — waitlist)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Pyth Network (price feeds)
# hermes-beta is retired — both devnet and mainnet use hermes.pyth.network
PYTH_WS_URL_DEVNET=wss://hermes.pyth.network/ws
PYTH_WS_URL_MAINNET=wss://hermes.pyth.network/ws
PYTH_REST_URL_DEVNET=https://hermes.pyth.network
PYTH_REST_URL_MAINNET=https://hermes.pyth.network

# Pyth Feed IDs — canonical IDs from https://pyth.network/developers/price-feed-ids
PYTH_FEED_SOL_USD=0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d
PYTH_FEED_BTC_USD=0xe62df6c8b4a85fe1a67db44dc12de5db330f7ac66b72dc658afedf0f4a415b43
PYTH_FEED_ETH_USD=0xff61491a931112ddf1bd8147cd1b641375f79f5825126d665480874634fd0ace
PYTH_FEED_USDC_USD=0xeaa020c61cc479712813461ce153894a96a6c00b21ed0cfc2798d1f9a9e9c94a
PYTH_FEED_USDT_USD=0x2b89b9dc8fdf9f34709a5b106b472f0f39bb6ca9ce04b0fd7f2e971688d2e53b
