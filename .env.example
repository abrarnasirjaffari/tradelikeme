# TradeLikeMe — Environment Variables
# Copy this to .env and fill in your values

# Helius RPC
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# Phantom Wallet (agent sub-account)
PHANTOM_PRIVATE_KEY=

# Solana
SOLANA_NETWORK=devnet
DEVNET_AGENT_KEYPAIR_PATH=~/.config/solana/devnet-agent.json

# AWS Bedrock (Claude Opus 4.6)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# WEEX
WEEX_API_KEY=
WEEX_SECRET=
WEEX_PASSPHRASE=

# Bybit
BYBIT_API_KEY=
BYBIT_SECRET=

# BingX
BINGX_API_KEY=
BINGX_SECRET=

# Binance
BINANCE_API_KEY=
BINANCE_SECRET=

# Bitget
BITGET_API_KEY=
BITGET_SECRET=
BITGET_PASSPHRASE=

# GitHub
GITHUB_PAT=

# Platform
PLATFORM_WALLET_PUBKEY=
PROGRAM_ID=

# Frontend (Supabase — waitlist)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
