# Dograh Voice Agent — Local Dev
# Fill in Deepgram + Cartesia keys, then: docker compose --profile dograh up
# Configure LLM/STT/TTS at: http://localhost:3010/model-configurations

# ─── AWS Bedrock (for Claude Sonnet 4.6 as LLM) ───────────────────────────────
# Configure via Dograh dashboard → Model Configurations → LLM → Bedrock
# Provider: bedrock  |  Model: us.anthropic.claude-sonnet-4-6
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
LLM_MODEL=us.anthropic.claude-sonnet-4-6

# ─── STT — Deepgram (free tier at deepgram.com) ───────────────────────────────
# Configure via Dograh dashboard → Model Configurations → Transcriber → Deepgram
DEEPGRAM_API_KEY=
STT_LANGUAGE=auto

# ─── TTS — Cartesia (free tier at cartesia.ai) ────────────────────────────────
# Configure via Dograh dashboard → Model Configurations → Voice → Cartesia
CARTESIA_API_KEY=
# Recommended voice for support: "Helpful Woman" or "Support Man"
CARTESIA_VOICE_ID=

# ─── Knowledge base (system prompt loaded by agent workflow) ──────────────────
SYSTEM_PROMPT_FILE=/app/kb/system_prompt.txt
