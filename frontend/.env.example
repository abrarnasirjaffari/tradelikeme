# ─────────────────────────────────────────────
# TradeLikeMe — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Supabase ──────────────────────────────────
# Project URL and anon/public key from:
# https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
# Must be a valid JWT (eyJ...) — get from Supabase dashboard → Settings → API → anon/public key
VITE_SUPABASE_ANON_KEY=eyJ...

# ── API Backend ───────────────────────────────
# FastAPI backend URL (no trailing slash)
# Dev: http://localhost:8001 | Prod: https://api.tradelikeme.xyz
VITE_API_URL=https://api.tradelikeme.xyz

# ── Auth Server ───────────────────────────────
# URL of the Hono auth server (no trailing slash)
# Dev: http://localhost:3001 | Prod: https://auth.tradelikeme.xyz
VITE_AUTH_URL=http://localhost:3001
# Comma-separated list of emails that get the admin role on signup
ADMIN_EMAILS=

# ── OAuth Providers ───────────────────────────
# Google: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# X/Twitter: https://developer.x.com → Projects & Apps → OAuth 2.0
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
